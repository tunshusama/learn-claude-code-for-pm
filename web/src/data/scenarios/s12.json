{
  "version": "s12",
  "title": "Task System",
  "description": "文件持久化的任务图会追踪状态、负责人和 blockedBy 依赖。",
  "steps": [
    {
      "type": "user_message",
      "content": "把发布拆成任务，并且在测试通过前阻塞部署。",
      "annotation": "用户要求的是可持久化的多步骤协作。"
    },
    {
      "type": "tool_call",
      "toolName": "create_task",
      "content": "{\"subject\":\"运行测试\"}",
      "annotation": "任务会作为 JSON 文件创建在 .tasks/ 下。"
    },
    {
      "type": "tool_call",
      "toolName": "create_task",
      "content": "{\"subject\":\"部署发布\",\"blockedBy\":[\"task_tests\"]}",
      "annotation": "blockedBy 表达依赖顺序。"
    },
    {
      "type": "tool_call",
      "toolName": "claim_task",
      "content": "{\"task_id\":\"task_deploy\",\"owner\":\"agent\"}",
      "annotation": "依赖完成前，认领会失败。"
    },
    {
      "type": "tool_result",
      "toolName": "claim_task",
      "content": "被阻塞： [\"task_tests\"]",
      "annotation": "任务图会阻止过早开工。"
    },
    {
      "type": "tool_call",
      "toolName": "complete_task",
      "content": "{\"task_id\":\"task_tests\"}",
      "annotation": "完成依赖后，下游任务可能被解锁。"
    },
    {
      "type": "tool_result",
      "toolName": "complete_task",
      "content": "已完成 task_tests\n已解锁：部署发布",
      "annotation": "Harness 会报告刚刚变成可执行的工作。"
    }
  ]
}
